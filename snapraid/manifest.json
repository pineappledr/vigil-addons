{
  "id": "snapraid",
  "name": "SnapRAID",
  "version": "2.0.0",
  "description": "SnapRAID array management and automation",
  "icon": "shield-check",
  "author": "Vigil Add-ons",
  "min_vigil_version": "3.0.0",
  "requires": ["snapraid"],
  "permissions": ["exec", "filesystem_read"],
  "pages": [
    {
      "id": "dashboard",
      "title": "Dashboard",
      "icon": "layout-dashboard",
      "default": true,
      "page_config": {
        "agent_selector": true,
        "refresh": {
          "manual": true,
          "auto_options": [
            {"value": "30", "label": "30s"},
            {"value": "60", "label": "1m"},
            {"value": "300", "label": "5m"}
          ]
        }
      },
      "components": [
        {
          "id": "config_summary",
          "type": "config-card",
          "title": "Configuration",
          "source": "agent_config",
          "config": {
            "source": "agent_config",
            "labels": {
              "maintenance_cron": "Maintenance Schedule",
              "scrub_cron": "Scrub Schedule",
              "max_deleted": "Deletion Threshold",
              "max_updated": "Update Threshold",
              "sync.pre_hash": "Pre-Hash",
              "scrub.plan": "Default Scrub Plan",
              "scrub.older_than_days": "Scrub Min Age (Days)",
              "scrub.auto_fix_bad_blocks": "Auto-Fix Bad Blocks"
            },
            "link_page": "automation",
              "link_params": ["agent_id"]
          }
        },
        {
          "id": "disk_status",
          "type": "smart-table",
          "title": "Disk Status",
          "source": "disk_status",
          "config": {
            "source": "disk_status",
            "columns": [
              {"key": "name", "label": "Disk"},
              {"key": "device", "label": "Device"},
              {"key": "used", "label": "Used", "format": "bytes"},
              {"key": "free", "label": "Free", "format": "bytes"},
              {"key": "wasted", "label": "Wasted", "format": "bytes"}
            ]
          }
        },
        {
          "id": "active_jobs",
          "type": "progress",
          "title": "Active Job",
          "config": {
            "source": "active_jobs"
          }
        },
        {
          "id": "disk_storage",
          "type": "disk-storage",
          "title": "Disk Storage",
          "source": "disk_storage",
          "config": {
            "source": "disk_storage",
            "thresholds": {"warning": 70, "danger": 90}
          }
        }
      ]
    },
    {
      "id": "operations",
      "title": "Operations",
      "icon": "terminal",
      "page_config": {
        "agent_selector": true
      },
      "components": [
        {
          "id": "command_form",
          "type": "form",
          "title": "Run Command",
          "config": {
            "actions": [
              {
                "id": "sync",
                "label": "Sync",
                "command": "sync",
                "description": "Update parity data. Runs pre-flight safety gates before execution.",
                "params": [
                  {"key": "force_zero", "label": "Force Zero Sync", "type": "toggle", "warning": true, "description": "Treats entire array as new data. For initial setup only."},
                  {"key": "force_thresholds", "label": "Bypass Threshold Checks", "type": "toggle", "warning": true, "description": "Skip diff threshold safety gates for the next sync only."}
                ]
              },
              {
                "id": "scrub",
                "label": "Scrub",
                "command": "scrub",
                "description": "Verify data integrity against parity.",
                "params": [
                  {"key": "plan", "label": "Plan", "type": "select", "options": [
                    {"value": "8", "label": "Standard (8%)"},
                    {"value": "bad", "label": "Bad Blocks Only"},
                    {"value": "new", "label": "New Blocks Only"},
                    {"value": "full", "label": "Full Scrub"}
                  ]}
                ]
              },
              {
                "id": "fix_bad",
                "label": "Fix Bad Blocks",
                "command": "fix",
                "description": "Repair blocks marked bad during scrub.",
                "confirm": "This will repair only blocks marked bad by scrub.",
                "params": [
                  {"key": "bad_blocks_only", "type": "hidden", "value": true}
                ]
              },
              {
                "id": "fix_disk",
                "label": "Fix Disk / Files",
                "command": "fix",
                "description": "Recover data for a specific disk or file pattern.",
                "confirm": "This will revert files to the last synced state.",
                "params": [
                  {"key": "disk", "label": "Disk Name (-d)", "type": "text"},
                  {"key": "filter", "label": "File Filter (-f)", "type": "text"}
                ]
              },
              {
                "id": "abort",
                "label": "Abort",
                "command": "abort",
                "description": "Send abort signal to the running operation.",
                "visible_when": "active_job"
              }
            ]
          }
        },
        {
          "id": "op_progress",
          "type": "progress",
          "title": "Active Job",
          "config": {
            "source": "active_jobs"
          }
        }
      ]
    },
    {
      "id": "automation",
      "title": "Automation",
      "icon": "clock",
      "page_config": {
        "agent_selector": true
      },
      "components": [
        {
          "id": "automation_form",
          "type": "form",
          "title": "Scheduler & Thresholds",
          "config": {
            "action": "config",
            "source": "agent_config",
            "fields": [
              {"key": "agent_id", "label": "Agent", "type": "select", "source": "addon_agents", "required": true},
              {"key": "maintenance_cron", "label": "Maintenance Schedule", "type": "cron", "description": "Full pipeline: touch, diff, gates, sync, scrub"},
              {"key": "scrub_cron", "label": "Scrub Schedule", "type": "cron", "description": "Independent scrub for periodic integrity verification"},
              {"key": "sync.pre_hash", "label": "Enable Pre-Hash", "type": "toggle", "description": "Hash files before writing parity. Slower but detects RAM errors."},
              {"key": "thresholds.max_deleted", "label": "Deletion Threshold", "type": "number", "default": 50, "description": "Maximum deleted files before aborting automated sync. Set to 0 to disable."},
              {"key": "thresholds.max_updated", "label": "Update Threshold", "type": "number", "default": -1, "description": "Maximum updated files before aborting. -1 to disable."},
              {"key": "scrub.plan", "label": "Scrub Plan", "type": "select", "default": "8", "options": [
                {"value": "bad", "label": "Bad Blocks Only"},
                {"value": "new", "label": "New Blocks Only"},
                {"value": "full", "label": "Full Scrub"},
                {"value": "8", "label": "8% (default)"}
              ], "description": "Default scrub plan for automated runs."},
              {"key": "scrub.older_than_days", "label": "Scrub Min Age (days)", "type": "number", "default": 10, "description": "Only scrub blocks older than this many days."},
              {"key": "scrub.auto_fix_bad_blocks", "label": "Auto-Fix Bad Blocks", "type": "toggle", "description": "Automatically run fix when bad blocks are detected."}
            ]
          }
        }
      ]
    },
    {
      "id": "agents",
      "title": "Agents",
      "icon": "server",
      "components": [
        {
          "id": "agent_list",
          "type": "smart-table",
          "title": "Registered Agents",
          "config": {
            "source": "addon_agents",
            "columns": [
              {"key": "agent_id", "label": "Agent ID"},
              {"key": "hostname", "label": "Hostname"},
              {"key": "status", "label": "Status", "format": "status_dot"},
              {"key": "last_seen_at", "label": "Last Seen", "format": "relative_time"},
              {"key": "version", "label": "Version"}
            ],
            "sortable": true,
            "default_sort": {"key": "agent_id", "direction": "asc"},
            "row_actions": [
              {
                "id": "delete-agent",
                "label": "Delete",
                "icon": "trash-2",
                "safety_tier": "red",
                "action": {
                  "method": "DELETE",
                  "endpoint": "/api/agents/{row.agent_id}"
                },
                "confirm": {
                  "title": "Delete agent {row.agent_id}?",
                  "message": "Removes {row.hostname} from the registry. The agent process re-registers itself on its next heartbeat unless you stop it too.",
                  "button_label": "Delete",
                  "button_variant": "danger",
                  "success_message": "Agent {row.agent_id} deleted",
                  "error_message": "Delete failed: {error}"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "id": "logs",
      "title": "Logs",
      "icon": "scroll-text",
      "page_config": {
        "agent_selector": true
      },
      "components": [
        {
          "id": "live_log_viewer",
          "type": "log-viewer",
          "title": "Live Output",
          "config": {
            "auto_scroll": true
          }
        },
        {
          "id": "job_history",
          "type": "smart-table",
          "title": "Job History",
          "config": {
            "source": "job_history",
            "columns": [
              {"key": "job_id", "label": "Job ID"},
              {"key": "job_type", "label": "Type"},
              {"key": "trigger", "label": "Trigger"},
              {"key": "started_at", "label": "Started", "format": "datetime"},
              {"key": "finished_at", "label": "Finished", "format": "datetime"},
              {"key": "status", "label": "Status", "format": "badge", "badge_map": {
                "running": "warning",
                "succeeded": "success",
                "failed": "critical",
                "cancelled": "muted"
              }},
              {"key": "exit_code", "label": "Exit Code"}
            ],
            "sortable": true,
            "filterable": true,
            "default_sort": {"key": "started_at", "direction": "desc"},
            "progress_indicator": {
              "field": "status",
              "busy_values": ["running"],
              "interval_seconds": 5
            },
            "row_actions": [
              {
                "id": "cancel-job",
                "label": "Cancel",
                "icon": "x-circle",
                "safety_tier": "yellow",
                "visible_when": {"field": "row.status", "equals": "running"},
                "action": {
                  "method": "DELETE",
                  "endpoint": "/api/jobs/{row.job_id}"
                },
                "confirm": {
                  "title": "Cancel job {row.job_id}?",
                  "message": "Sends an abort signal to the running {row.job_type} on agent {row.agent_id}. The partial work completed so far will not be rolled back.",
                  "button_label": "Cancel Job",
                  "button_variant": "warning",
                  "success_message": "Cancel signal sent to job {row.job_id}",
                  "error_message": "Cancel failed: {error}"
                }
              }
            ]
          }
        }
      ]
    }
  ]
}
