FROM --platform=$BUILDPLATFORM golang:1.26.2-alpine AS builder
ARG TARGETOS TARGETARCH
ARG VERSION=dev
WORKDIR /src
COPY shared/ shared/
COPY zfs-manager/ zfs-manager/
WORKDIR /src/zfs-manager
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -ldflags="-s -w -X main.version=$VERSION" \
    -o /zfs-agent ./cmd/agent

FROM alpine:3.23.4
RUN apk upgrade --no-cache && apk add --no-cache ca-certificates tzdata
RUN mkdir -p /data
COPY --from=builder /zfs-agent /usr/local/bin/zfs-agent
VOLUME ["/data"]
EXPOSE 9600
ENTRYPOINT ["zfs-agent"]
