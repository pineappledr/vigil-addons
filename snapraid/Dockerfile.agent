FROM --platform=$BUILDPLATFORM golang:1.26.1-alpine AS builder
ARG TARGETOS TARGETARCH
ARG VERSION=dev
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -ldflags="-s -w -X main.version=$VERSION" \
    -o /snapraid-agent ./cmd/agent

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
RUN mkdir -p /var/lib/vigil-snapraid-agent
COPY --from=builder /snapraid-agent /usr/local/bin/snapraid-agent
VOLUME ["/var/lib/vigil-snapraid-agent"]
EXPOSE 9400
ENTRYPOINT ["snapraid-agent"]
