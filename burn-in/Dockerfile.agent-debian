FROM --platform=$BUILDPLATFORM golang:1.26.1 AS builder
ARG TARGETOS TARGETARCH
ARG VERSION=dev
WORKDIR /src
COPY shared/ shared/
COPY burn-in/ burn-in/
WORKDIR /src/burn-in
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -ldflags="-s -w -X main.version=$VERSION" \
    -o /burnin-agent ./cmd/agent

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates tzdata \
    smartmontools e2fsprogs util-linux gdisk \
    xfsprogs btrfs-progs dosfstools \
    && rm -rf /var/lib/apt/lists/*
RUN mkdir -p /var/lib/vigil-agent/logs
COPY --from=builder /burnin-agent /usr/local/bin/burnin-agent
VOLUME ["/var/lib/vigil-agent/logs"]
EXPOSE 9200
ENTRYPOINT ["burnin-agent"]
