{
  "name": "ZFS Manager",
  "version": "0.3.0",
  "description": "ZFS pool, dataset, and snapshot management for homelab servers",
  "author": "Vigil Add-ons",
  "docker_image": "ghcr.io/pineappledr/vigil-addons-zfs-manager:latest",
  "pages": [
    {
      "id": "pools",
      "title": "Pools",
      "icon": "database",
      "page_config": {
        "agent_selector": true,
        "refresh": {
          "manual": true,
          "auto_options": [
            { "value": 60, "label": "1 Minute" },
            { "value": 300, "label": "5 Minutes" }
          ]
        }
      },
      "components": [
        {
          "type": "smart-table",
          "id": "pool-list",
          "title": "ZFS Pools",
          "config": {
            "source": "/api/pools",
            "columns": [
              { "key": "name",   "label": "Pool",        "sortable": true },
              { "key": "health", "label": "Health",      "sortable": true, "badge": {
                "ONLINE":   "success",
                "DEGRADED": "warning",
                "FAULTED":  "danger",
                "OFFLINE":  "muted",
                "REMOVED":  "muted",
                "UNAVAIL":  "danger"
              }},
              { "key": "size",  "label": "Size",        "sortable": true, "format": "bytes" },
              { "key": "alloc", "label": "Used",        "sortable": true, "format": "bytes" },
              { "key": "free",  "label": "Free",        "sortable": true, "format": "bytes" },
              { "key": "frag",  "label": "Frag %",      "sortable": true, "suffix": "%" },
              { "key": "dedup", "label": "Dedup",       "sortable": true, "suffix": "x" },
              { "key": "last_scrub",   "label": "Last Scrub",   "sortable": false },
              { "key": "scrub_status", "label": "Scrub Status", "sortable": false }
            ],
            "sortable": true,
            "default_sort": { "key": "name", "direction": "asc" },
            "expandable": true,
            "expand_key": "vdevs",
            "row_actions": [
              {
                "id": "start-scrub",
                "label": "Start Scrub",
                "icon": "refresh-cw",
                "safety_tier": "green",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/scrub/start",
                  "body_map": { "pool": "row.name" },
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "scrub", "scrub_op": "start" },
                    "body_map": { "pool": "row.name" }
                  }
                },
                "confirm": {
                  "title": "Start Scrub",
                  "message": "Start a scrub on pool {row.name}?",
                  "show_command": true,
                  "button_label": "Start Scrub"
                }
              },
              {
                "id": "pause-scrub",
                "label": "Pause Scrub",
                "icon": "pause",
                "safety_tier": "yellow",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/scrub/pause",
                  "body_map": { "pool": "row.name" },
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "scrub", "scrub_op": "pause" },
                    "body_map": { "pool": "row.name" }
                  }
                },
                "confirm": {
                  "title": "Pause Scrub",
                  "message": "Pause the running scrub on pool {row.name}?",
                  "show_command": true,
                  "button_label": "Pause"
                }
              },
              {
                "id": "cancel-scrub",
                "label": "Cancel Scrub",
                "icon": "x-circle",
                "safety_tier": "yellow",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/scrub/cancel",
                  "body_map": { "pool": "row.name" },
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "scrub", "scrub_op": "cancel" },
                    "body_map": { "pool": "row.name" }
                  }
                },
                "confirm": {
                  "title": "Cancel Scrub",
                  "message": "Cancel the running scrub on pool {row.name}?",
                  "show_command": true,
                  "button_label": "Cancel Scrub"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "id": "datasets",
      "title": "Datasets",
      "icon": "folder-tree",
      "page_config": {
        "agent_selector": true,
        "refresh": {
          "manual": true,
          "auto_options": [
            { "value": 60, "label": "1 Minute" },
            { "value": 300, "label": "5 Minutes" }
          ]
        }
      },
      "components": [
        {
          "type": "smart-table",
          "id": "dataset-list",
          "title": "Datasets",
          "config": {
            "source": "/api/datasets",
            "columns": [
              { "key": "name",        "label": "Dataset",     "sortable": true },
              { "key": "used",        "label": "Used",        "sortable": true, "format": "bytes" },
              { "key": "avail",       "label": "Available",   "sortable": true, "format": "bytes" },
              { "key": "refer",       "label": "Referenced",  "sortable": true, "format": "bytes" },
              { "key": "compress",    "label": "Compression", "sortable": true },
              { "key": "record_size", "label": "Record Size", "sortable": true, "format": "bytes" },
              { "key": "mountpoint",  "label": "Mountpoint",  "sortable": false },
              { "key": "atime",       "label": "Atime",       "sortable": true },
              { "key": "sync",        "label": "Sync",        "sortable": true }
            ],
            "sortable": true,
            "filterable": true,
            "default_sort": { "key": "name", "direction": "asc" },
            "row_actions": [
              {
                "id": "edit-dataset",
                "label": "Edit Properties",
                "icon": "edit",
                "safety_tier": "yellow",
                "action": {
                  "method": "PUT",
                  "endpoint": "/api/datasets",
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "set_properties" },
                    "body_map": { "name": "row.name" }
                  }
                },
                "form": {
                  "title": "Edit Dataset Properties — {row.name}",
                  "show_command": true,
                  "fields": [
                    { "key": "name", "type": "hidden", "value_from": "row.name" },
                    {
                      "key": "properties.compression",
                      "label": "Compression",
                      "type": "select",
                      "options": [
                        { "value": "lz4", "label": "LZ4 (recommended)" },
                        { "value": "zstd", "label": "ZSTD" },
                        { "value": "gzip", "label": "GZIP" },
                        { "value": "off", "label": "Off" }
                      ],
                      "value_from": "row.compress"
                    },
                    {
                      "key": "properties.recordsize",
                      "label": "Record Size",
                      "type": "select",
                      "options": [
                        { "value": "4K", "label": "4K" },
                        { "value": "8K", "label": "8K" },
                        { "value": "16K", "label": "16K (Database)" },
                        { "value": "32K", "label": "32K" },
                        { "value": "64K", "label": "64K (VM/App)" },
                        { "value": "128K", "label": "128K (General)" },
                        { "value": "256K", "label": "256K" },
                        { "value": "512K", "label": "512K" },
                        { "value": "1M", "label": "1M (Media)" }
                      ],
                      "hint": "Changing record size only affects new data, not existing blocks"
                    },
                    {
                      "key": "properties.atime",
                      "label": "Access Time (atime)",
                      "type": "select",
                      "options": [
                        { "value": "off", "label": "Off (recommended)" },
                        { "value": "on", "label": "On" }
                      ],
                      "value_from": "row.atime"
                    },
                    {
                      "key": "properties.sync",
                      "label": "Sync",
                      "type": "select",
                      "options": [
                        { "value": "standard", "label": "Standard" },
                        { "value": "always", "label": "Always (safest)" },
                        { "value": "disabled", "label": "Disabled (fastest)" }
                      ],
                      "value_from": "row.sync"
                    },
                    {
                      "key": "properties.quota",
                      "label": "Quota",
                      "type": "text",
                      "placeholder": "e.g. 100G, 1T, or none",
                      "hint": "Maximum space this dataset can consume. Use 'none' to remove."
                    },
                    {
                      "key": "properties.reservation",
                      "label": "Reservation",
                      "type": "text",
                      "placeholder": "e.g. 50G, or none",
                      "hint": "Guaranteed minimum space for this dataset. Use 'none' to remove."
                    }
                  ],
                  "button_label": "Apply Changes"
                }
              },
              {
                "id": "take-snapshot",
                "label": "Take Snapshot",
                "icon": "camera",
                "safety_tier": "green",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/snapshots",
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "create_snapshot" },
                    "body_map": { "dataset": "row.name" }
                  }
                },
                "form": {
                  "title": "Take Snapshot of {row.name}",
                  "show_command": true,
                  "fields": [
                    { "key": "dataset", "type": "hidden", "value_from": "row.name" },
                    {
                      "key": "name",
                      "label": "Snapshot Name",
                      "type": "text",
                      "placeholder": "manual-2026-04-07-120000 (auto-generated if empty)",
                      "hint": "Leave blank for auto-generated timestamp name"
                    },
                    {
                      "key": "recursive",
                      "label": "Recursive",
                      "type": "checkbox",
                      "hint": "Also snapshot all child datasets"
                    }
                  ],
                  "button_label": "Take Snapshot"
                }
              },
              {
                "id": "delete-dataset",
                "label": "Delete Dataset",
                "icon": "trash-2",
                "safety_tier": "red",
                "action": {
                  "method": "DELETE",
                  "endpoint": "/api/datasets",
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "destroy_dataset" },
                    "body_map": { "name": "row.name" }
                  }
                },
                "confirm": {
                  "title": "Delete Dataset",
                  "message": "This will permanently destroy the dataset {row.name} and all its data. This action cannot be undone.",
                  "show_command": true,
                  "require_type_confirm": true,
                  "confirm_value": "{row.name}",
                  "confirm_label": "Type the full dataset name to confirm",
                  "confirm_key": "confirm",
                  "button_label": "Delete Dataset",
                  "button_variant": "danger",
                  "extra_fields": [
                    { "key": "name", "type": "hidden", "value_from": "row.name" },
                    {
                      "key": "recursive",
                      "label": "Recursive (include children and snapshots)",
                      "type": "checkbox"
                    }
                  ]
                }
              }
            ],
            "toolbar_actions": [
              {
                "id": "create-dataset",
                "label": "Create Dataset",
                "icon": "folder-plus",
                "safety_tier": "yellow",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/datasets",
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "create_dataset" }
                  }
                },
                "form": {
                  "title": "Create Dataset",
                  "show_command": true,
                  "fields": [
                    {
                      "key": "parent",
                      "label": "Parent Dataset",
                      "type": "select",
                      "options_from": "/api/datasets",
                      "option_value": "name",
                      "option_label": "name",
                      "required": true
                    },
                    {
                      "key": "name",
                      "label": "Dataset Name",
                      "type": "text",
                      "placeholder": "my-dataset",
                      "required": true,
                      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$",
                      "hint": "Only letters, numbers, dots, hyphens, underscores. No spaces."
                    },
                    {
                      "key": "preset",
                      "label": "Preset",
                      "type": "select",
                      "options": [
                        { "value": "",        "label": "— No Preset (manual) —" },
                        { "value": "general", "label": "General Purpose — good for most files and documents" },
                        { "value": "media",   "label": "Media Storage — optimized for large video/music files" },
                        { "value": "vm",      "label": "VM/App Storage — balanced for virtual machines and containers" },
                        { "value": "db",      "label": "Database — tuned for databases that need data safety" }
                      ],
                      "hint": "Presets auto-configure record size, compression, atime, and sync"
                    },
                    {
                      "key": "quota",
                      "label": "Quota (optional)",
                      "type": "text",
                      "placeholder": "e.g. 100G, 1T",
                      "hint": "Maximum space this dataset can consume"
                    },
                    {
                      "key": "reservation",
                      "label": "Reservation (optional)",
                      "type": "text",
                      "placeholder": "e.g. 50G",
                      "hint": "Guaranteed minimum space for this dataset"
                    }
                  ],
                  "button_label": "Create Dataset"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "id": "snapshots",
      "title": "Snapshots",
      "icon": "camera",
      "page_config": {
        "agent_selector": true,
        "refresh": {
          "manual": true,
          "auto_options": [
            { "value": 60, "label": "1 Minute" },
            { "value": 300, "label": "5 Minutes" }
          ]
        }
      },
      "components": [
        {
          "type": "smart-table",
          "id": "snapshot-list",
          "title": "Snapshots",
          "config": {
            "source": "/api/snapshots",
            "columns": [
              { "key": "dataset",     "label": "Dataset",    "sortable": true },
              { "key": "snap_name",   "label": "Snapshot",   "sortable": true },
              { "key": "creation",    "label": "Created",    "sortable": true, "format": "timestamp" },
              { "key": "used",        "label": "Used",       "sortable": true, "format": "bytes" },
              { "key": "referenced",  "label": "Referenced", "sortable": true, "format": "bytes" }
            ],
            "sortable": true,
            "filterable": true,
            "default_sort": { "key": "creation", "direction": "desc" },
            "row_actions": [
              {
                "id": "rollback-snapshot",
                "label": "Rollback",
                "icon": "rotate-ccw",
                "safety_tier": "red",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/snapshots/rollback",
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "rollback" },
                    "body_map": { "name": "row.full_name" }
                  }
                },
                "confirm": {
                  "title": "Rollback to Snapshot",
                  "message": "This will revert {row.dataset} to how it looked when snapshot {row.snap_name} was taken. Any data written after this snapshot will be permanently lost.",
                  "show_command": true,
                  "require_type_confirm": true,
                  "confirm_value": "{row.dataset}",
                  "confirm_label": "Type the dataset name to confirm",
                  "confirm_key": "confirm",
                  "button_label": "Rollback",
                  "button_variant": "danger",
                  "extra_fields": [
                    { "key": "name", "type": "hidden", "value_from": "row.full_name" },
                    {
                      "key": "depth",
                      "label": "Rollback Depth",
                      "type": "select",
                      "options": [
                        { "value": "latest",       "label": "Just this snapshot (most recent only)" },
                        { "value": "intermediate", "label": "This and newer snapshots (destroys intermediate snapshots)" },
                        { "value": "all",          "label": "Everything after this (destroys all newer snapshots and bookmarks)" }
                      ],
                      "required": true
                    }
                  ]
                }
              },
              {
                "id": "delete-snapshot",
                "label": "Delete",
                "icon": "trash-2",
                "safety_tier": "red",
                "action": {
                  "method": "DELETE",
                  "endpoint": "/api/snapshots",
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "destroy_snapshot" },
                    "body_map": { "name": "row.full_name" }
                  }
                },
                "confirm": {
                  "title": "Delete Snapshot",
                  "message": "Permanently delete snapshot {row.full_name}? This cannot be undone.",
                  "show_command": true,
                  "require_type_confirm": true,
                  "confirm_value": "{row.full_name}",
                  "confirm_label": "Type the full snapshot name to confirm",
                  "confirm_key": "confirm",
                  "button_label": "Delete Snapshot",
                  "button_variant": "danger",
                  "extra_fields": [
                    { "key": "name", "type": "hidden", "value_from": "row.full_name" }
                  ]
                }
              }
            ],
            "toolbar_actions": [
              {
                "id": "take-snapshot",
                "label": "Take Snapshot",
                "icon": "camera",
                "safety_tier": "green",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/snapshots",
                  "preview": {
                    "endpoint": "/api/preview",
                    "body": { "action": "create_snapshot" }
                  }
                },
                "form": {
                  "title": "Take Snapshot",
                  "show_command": true,
                  "fields": [
                    {
                      "key": "dataset",
                      "label": "Dataset",
                      "type": "select",
                      "options_from": "/api/datasets",
                      "option_value": "name",
                      "option_label": "name",
                      "required": true
                    },
                    {
                      "key": "name",
                      "label": "Snapshot Name",
                      "type": "text",
                      "placeholder": "auto-generated if empty",
                      "hint": "Leave blank for auto-generated timestamp name (e.g. manual-2026-04-07-120000)"
                    },
                    {
                      "key": "recursive",
                      "label": "Recursive (include child datasets)",
                      "type": "checkbox"
                    }
                  ],
                  "button_label": "Take Snapshot"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "id": "scheduled-tasks",
      "title": "Scheduled Tasks",
      "icon": "clock",
      "page_config": {
        "agent_selector": true,
        "refresh": {
          "manual": true,
          "auto_options": [
            { "value": 30, "label": "30 Seconds" },
            { "value": 60, "label": "1 Minute" }
          ]
        }
      },
      "components": [
        {
          "type": "smart-table",
          "id": "task-list",
          "title": "Scheduled Tasks",
          "config": {
            "source": "/api/tasks",
            "columns": [
              { "key": "id",        "label": "ID",        "sortable": true },
              { "key": "task_type", "label": "Type",      "sortable": true, "badge": {
                "snapshot": "info",
                "scrub":    "warning"
              }},
              { "key": "target",    "label": "Target",    "sortable": true },
              { "key": "schedule",  "label": "Schedule",  "sortable": false },
              { "key": "prefix",    "label": "Prefix",    "sortable": false },
              { "key": "retention", "label": "Retention",  "sortable": true, "suffix": " snapshots" },
              { "key": "recursive", "label": "Recursive", "sortable": false, "format": "boolean" },
              { "key": "enabled",   "label": "Enabled",   "sortable": true, "badge": {
                "true":  "success",
                "false": "muted"
              }},
              { "key": "next_run",  "label": "Next Run",  "sortable": true, "format": "timestamp" }
            ],
            "sortable": true,
            "default_sort": { "key": "id", "direction": "asc" },
            "row_actions": [
              {
                "id": "edit-task",
                "label": "Edit",
                "icon": "edit",
                "safety_tier": "yellow",
                "action": {
                  "method": "PUT",
                  "endpoint": "/api/tasks/{row.id}"
                },
                "form": {
                  "title": "Edit Scheduled Task #{row.id}",
                  "fields": [
                    {
                      "key": "target",
                      "label": "Target",
                      "type": "text",
                      "value_from": "row.target",
                      "required": true,
                      "hint": "Dataset name (for snapshots) or pool name (for scrubs)"
                    },
                    {
                      "key": "schedule",
                      "label": "Schedule",
                      "type": "select",
                      "options": [
                        { "value": "0 * * * *",     "label": "Every hour" },
                        { "value": "0 */6 * * *",   "label": "Every 6 hours" },
                        { "value": "0 0 * * *",     "label": "Daily at midnight" },
                        { "value": "0 0 * * 0",     "label": "Weekly on Sunday" },
                        { "value": "0 0 1 * *",     "label": "Monthly (1st)" },
                        { "value": "0 0 1,15 * *",  "label": "Bi-weekly (1st & 15th)" }
                      ],
                      "allow_custom": true,
                      "custom_label": "Custom (cron expression)",
                      "value_from": "row.schedule",
                      "required": true,
                      "hint": "Standard 5-field cron expression (minute hour day month weekday)"
                    },
                    {
                      "key": "prefix",
                      "label": "Naming Prefix",
                      "type": "text",
                      "value_from": "row.prefix",
                      "hint": "Snapshots will be named: prefix-2026-04-07-120000"
                    },
                    {
                      "key": "retention",
                      "label": "Retention (snapshots to keep)",
                      "type": "number",
                      "value_from": "row.retention",
                      "hint": "0 = unlimited. Older snapshots matching this prefix are automatically deleted."
                    },
                    {
                      "key": "recursive",
                      "label": "Recursive",
                      "type": "checkbox",
                      "value_from": "row.recursive"
                    },
                    {
                      "key": "enabled",
                      "label": "Enabled",
                      "type": "checkbox",
                      "value_from": "row.enabled"
                    }
                  ],
                  "button_label": "Save Changes"
                }
              },
              {
                "id": "delete-task",
                "label": "Delete",
                "icon": "trash-2",
                "safety_tier": "red",
                "action": {
                  "method": "DELETE",
                  "endpoint": "/api/tasks/{row.id}"
                },
                "confirm": {
                  "title": "Delete Scheduled Task",
                  "message": "Delete the {row.task_type} task for {row.target}? Existing snapshots will not be removed.",
                  "button_label": "Delete Task",
                  "button_variant": "danger"
                }
              }
            ],
            "toolbar_actions": [
              {
                "id": "create-snapshot-task",
                "label": "Add Snapshot Task",
                "icon": "camera",
                "safety_tier": "green",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/tasks"
                },
                "form": {
                  "title": "Create Periodic Snapshot Task",
                  "fields": [
                    { "key": "task_type", "type": "hidden", "value": "snapshot" },
                    {
                      "key": "target",
                      "label": "Dataset",
                      "type": "select",
                      "options_from": "/api/datasets",
                      "option_value": "name",
                      "option_label": "name",
                      "required": true
                    },
                    {
                      "key": "schedule",
                      "label": "Schedule",
                      "type": "select",
                      "options": [
                        { "value": "0 * * * *",     "label": "Every hour" },
                        { "value": "0 */6 * * *",   "label": "Every 6 hours" },
                        { "value": "0 0 * * *",     "label": "Daily at midnight" },
                        { "value": "0 0 * * 0",     "label": "Weekly on Sunday" },
                        { "value": "0 0 1 * *",     "label": "Monthly (1st)" }
                      ],
                      "allow_custom": true,
                      "custom_label": "Custom (cron expression)",
                      "required": true,
                      "hint": "Standard 5-field cron expression"
                    },
                    {
                      "key": "prefix",
                      "label": "Naming Prefix",
                      "type": "text",
                      "placeholder": "auto",
                      "hint": "Snapshots named: prefix-2026-04-07-120000"
                    },
                    {
                      "key": "retention",
                      "label": "Retention",
                      "type": "select",
                      "options": [
                        { "value": "0",  "label": "Unlimited (no auto-delete)" },
                        { "value": "24", "label": "Keep last 24 snapshots" },
                        { "value": "7",  "label": "Keep last 7 snapshots" },
                        { "value": "4",  "label": "Keep last 4 snapshots" },
                        { "value": "12", "label": "Keep last 12 snapshots" }
                      ],
                      "allow_custom": true,
                      "custom_label": "Custom count",
                      "hint": "Older snapshots matching this prefix are automatically deleted"
                    },
                    {
                      "key": "recursive",
                      "label": "Recursive (include child datasets)",
                      "type": "checkbox"
                    }
                  ],
                  "button_label": "Create Task"
                }
              },
              {
                "id": "create-scrub-task",
                "label": "Add Scrub Task",
                "icon": "refresh-cw",
                "safety_tier": "green",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/tasks"
                },
                "form": {
                  "title": "Create Scheduled Scrub Task",
                  "fields": [
                    { "key": "task_type", "type": "hidden", "value": "scrub" },
                    {
                      "key": "target",
                      "label": "Pool",
                      "type": "select",
                      "options_from": "/api/pools",
                      "option_value": "name",
                      "option_label": "name",
                      "required": true
                    },
                    {
                      "key": "schedule",
                      "label": "Schedule",
                      "type": "select",
                      "options": [
                        { "value": "0 2 * * 0",     "label": "Weekly (Sunday 2 AM)" },
                        { "value": "0 2 1,15 * *",  "label": "Bi-weekly (1st & 15th, 2 AM)" },
                        { "value": "0 2 1 * *",     "label": "Monthly (1st, 2 AM)" }
                      ],
                      "allow_custom": true,
                      "custom_label": "Custom (cron expression)",
                      "required": true,
                      "hint": "Standard 5-field cron expression"
                    }
                  ],
                  "button_label": "Create Task"
                }
              }
            ]
          }
        },
        {
          "type": "smart-table",
          "id": "job-history",
          "title": "Job History",
          "config": {
            "source": "/api/jobs",
            "columns": [
              { "key": "id",          "label": "ID",        "sortable": true },
              { "key": "job_type",    "label": "Type",      "sortable": true, "badge": {
                "snapshot": "info",
                "scrub":    "warning"
              }},
              { "key": "trigger",     "label": "Trigger",   "sortable": true },
              { "key": "started_at",  "label": "Started",   "sortable": true, "format": "timestamp" },
              { "key": "finished_at", "label": "Finished",  "sortable": true, "format": "timestamp" },
              { "key": "status",      "label": "Status",    "sortable": true, "badge": {
                "success": "success",
                "error":   "danger",
                "running": "warning"
              }},
              { "key": "message",     "label": "Message",   "sortable": false }
            ],
            "sortable": true,
            "default_sort": { "key": "started_at", "direction": "desc" }
          }
        }
      ]
    },
    {
      "id": "retention",
      "title": "Retention",
      "icon": "pie-chart",
      "page_config": {
        "agent_selector": true,
        "refresh": {
          "manual": true,
          "auto_options": [
            { "value": 60, "label": "1 Minute" },
            { "value": 300, "label": "5 Minutes" }
          ]
        }
      },
      "components": [
        {
          "type": "smart-table",
          "id": "retention-stats",
          "title": "Snapshot Retention by Dataset",
          "config": {
            "source": "/api/retention",
            "columns": [
              { "key": "dataset",         "label": "Dataset",           "sortable": true },
              { "key": "snapshot_count",  "label": "Snapshots",        "sortable": true },
              { "key": "total_used",      "label": "Space Used",       "sortable": true, "format": "bytes" },
              { "key": "oldest_snapshot", "label": "Oldest Snapshot",  "sortable": true, "format": "timestamp" },
              { "key": "newest_snapshot", "label": "Newest Snapshot",  "sortable": true, "format": "timestamp" }
            ],
            "sortable": true,
            "filterable": true,
            "default_sort": { "key": "snapshot_count", "direction": "desc" },
            "row_actions": [
              {
                "id": "cleanup-snapshots",
                "label": "Cleanup Old Snapshots",
                "icon": "trash",
                "safety_tier": "red",
                "action": {
                  "method": "POST",
                  "endpoint": "/api/retention/cleanup"
                },
                "confirm": {
                  "title": "Cleanup Old Snapshots",
                  "message": "Delete all snapshots older than the specified number of days for dataset {row.dataset}.",
                  "show_command": false,
                  "require_type_confirm": true,
                  "confirm_value": "{row.dataset}",
                  "confirm_label": "Type the dataset name to confirm",
                  "confirm_key": "confirm",
                  "button_label": "Delete Old Snapshots",
                  "button_variant": "danger",
                  "extra_fields": [
                    { "key": "dataset", "type": "hidden", "value_from": "row.dataset" },
                    {
                      "key": "older_than_days",
                      "label": "Delete snapshots older than (days)",
                      "type": "number",
                      "placeholder": "30",
                      "required": true,
                      "hint": "All snapshots for this dataset created more than this many days ago will be deleted"
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    },
    {
      "id": "agents",
      "title": "Agents",
      "icon": "server",
      "components": [
        {
          "type": "smart-table",
          "id": "agent-list",
          "title": "Registered Agents",
          "config": {
            "source": "/api/agents",
            "columns": [
              { "key": "agent_id",      "label": "Agent ID",   "sortable": true },
              { "key": "hostname",      "label": "Hostname",   "sortable": true },
              { "key": "status",        "label": "Status",     "sortable": true, "badge": {
                "online":  "success",
                "offline": "muted"
              }},
              { "key": "arch",          "label": "Arch",       "sortable": true },
              { "key": "version",       "label": "Version",    "sortable": false },
              { "key": "last_seen_at",  "label": "Last Seen",  "sortable": true, "format": "timestamp" }
            ],
            "sortable": true,
            "default_sort": { "key": "agent_id", "direction": "asc" }
          }
        },
        {
          "type": "deploy-wizard",
          "id": "add-zfs-agent",
          "title": "Add ZFS Agent",
          "config": {
            "target_label": "Agent",
            "docker": {
              "image": "ghcr.io/pineappledr/vigil-addons-zfs-agent",
              "default_tag": "latest",
              "container_name": "zfs-agent",
              "privileged": true,
              "ports": ["9600:9600"],
              "volumes": [
                "zfs-agent-data:/data",
                "/dev/zfs:/dev/zfs",
                "/sbin/zpool:/sbin/zpool:ro",
                "/sbin/zfs:/sbin/zfs:ro",
                "/lib:/lib:ro",
                "/lib64:/lib64:ro",
                "/usr/lib:/usr/lib:ro"
              ],
              "named_volumes": ["zfs-agent-data"],
              "environment": {
                "VIGIL_ZFS_AGENT_HUB_URL":        { "source": "prefill",    "key": "hub_url", "label": "Manager URL" },
                "VIGIL_ZFS_AGENT_HUB_PSK":        { "source": "prefill",    "key": "hub_psk", "label": "Hub PSK", "secret": true, "rotate_action": "rotate-psk" },
                "VIGIL_ZFS_AGENT_ID":             { "source": "user_input", "label": "Agent ID", "placeholder": "nas-01" },
                "VIGIL_ZFS_AGENT_ADVERTISE_ADDR": { "source": "user_input", "label": "Advertise Address", "placeholder": "http://192.168.1.100:9600", "hint": "URL where the Manager can reach this agent" },
                "VIGIL_ZFS_AGENT_LISTEN_PORT":    { "source": "literal",    "value": "9600" },
                "TZ":                             { "source": "literal",    "value": "${TZ:-UTC}" }
              },
              "platforms": {
                "linux": {
                  "label": "Standard Linux",
                  "hint": "Deploy on any Linux host with ZFS installed. The agent mounts host ZFS binaries — use the Debian image for Proxmox/Ubuntu/Debian hosts."
                }
              }
            },
            "prefill_endpoint": "/api/deploy-info"
          }
        }
      ]
    }
  ]
}
